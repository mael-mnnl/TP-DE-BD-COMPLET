'Contenu de la vue vue_stats_reparateur_types_velos :'

SQL> CREATE OR REPLACE VIEW vue_stats_reparateur_types_velos AS
  2  SELECT
  3      rep.login,
  4      tv.libelle       AS type_velo,
  5      COUNT(op.id_operation)  AS nb_operations,
  6      SUM(op.cout)            AS cout_total
  7  FROM reparateur rep
  8  JOIN operation   op  ON rep.id_reparateur = op.id_reparateur
  9  JOIN reparation  r   ON op.id_reparation  = r.id_reparation
  10 JOIN velo        v   ON r.id_velo         = v.id_velo
  11 JOIN detail_velo dv  ON v.id_velo         = dv.id_velo
  12 JOIN type_velo   tv  ON dv.id_type        = tv.id_type
  13 GROUP BY rep.login, tv.libelle
  14 ORDER BY rep.login, tv.libelle;

