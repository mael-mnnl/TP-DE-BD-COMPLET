'Contenu de la vue vue_reparations_en_cours :'

SQL> CREATE OR REPLACE VIEW vue_reparations_en_cours AS
  2  SELECT
  3      r.id_reparation,
  4      r.etat,
  5      r.duree_prevue,
  6      r.date_debut_prevue,
  7      r.date_fin_prevue,
  8      r.date_debut_reelle,
  9      r.date_fin_reelle,
  10     r.cout_total,
  11     v.id_velo,
  12     v.num_velo
  13 FROM reparation r
  14 JOIN velo v ON r.id_velo = v.id_velo
  15 WHERE r.etat != 'terminee';

