'Contenu de la vue vue_reparations_clients :'

SQL> CREATE OR REPLACE VIEW vue_reparations_clients AS
  2  SELECT
  3      r.id_reparation,
  4      r.etat,
  5      r.duree_prevue,
  6      r.date_debut_prevue,
  7      r.date_fin_prevue,
  8      r.cout_total,
  9      v.num_velo,
  10     c.nom,
  11     c.prenom,
  12     c.email,
  13     c.tel
  14 FROM reparation r
  15 JOIN velo v      ON r.id_velo    = v.id_velo
  16 JOIN depot d     ON v.id_velo    = d.id_velo
  17 JOIN client c    ON d.id_client  = c.id_client
  18 ORDER BY r.id_reparation;

