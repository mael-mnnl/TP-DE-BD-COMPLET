'Résultat de la requête:'

SQL> SELECT
  2      r.id_reparation,
  3      r.duree_prevue,
  4      r.date_debut_prevue,
  5      r.date_fin_prevue,
  6      (r.date_fin_reelle - r.date_debut_reelle) AS "DureeRel(J)"
  7  FROM reparation r
  8  WHERE r.etat = 'terminee'
  9    AND EXTRACT(YEAR FROM r.date_debut_reelle) = 2023
 10    AND (r.date_fin_reelle - r.date_debut_reelle) > r.duree_prevue
 11  ORDER BY r.id_reparation;

